# Публичный URL приложения (после деплоя на Vercel)
NEXT_PUBLIC_URL=https://your-app.vercel.app

# Coinbase Developer Platform API Key (опционально, для расширенных фич)
NEXT_PUBLIC_CDP_API_KEY=

# Farcaster Account Association (генерируется на base.dev)
NEXT_PUBLIC_FARCASTER_HEADER=
NEXT_PUBLIC_FARCASTER_PAYLOAD=
NEXT_PUBLIC_FARCASTER_SIGNATURE=

# Neynar API Key (для Farcaster интеграции — бесплатный план на neynar.com)
NEYNAR_API_KEY=

# JWT секрет для аутентификации
JWT_SECRET=your-random-secret-here
